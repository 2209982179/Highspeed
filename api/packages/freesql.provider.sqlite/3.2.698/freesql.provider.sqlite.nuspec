<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>FreeSql.Provider.Sqlite</id>
    <version>3.2.698</version>
    <title>FreeSql.Provider.Sqlite</title>
    <authors>FreeSql,ncc,YeXiangQin</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>logo.png</icon>
    <projectUrl>https://github.com/2881099/FreeSql</projectUrl>
    <description>FreeSql 数据库实现，基于 Sqlite 3.0，支持 .NetCore、.NetFramework、Xamarin</description>
    <tags>FreeSql ORM sqlite</tags>
    <repository type="git" url="https://github.com/2881099/FreeSql" commit="70036d4235ef8a7754f97821a60361b982b27ac6" />
    <dependencies>
      <group targetFramework=".NETFramework4.0">
        <dependency id="FreeSql" version="3.2.698" exclude="Build,Analyzers" />
        <dependency id="System.Data.SQLite.Core" version="1.0.115.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETFramework4.5">
        <dependency id="FreeSql" version="3.2.698" exclude="Build,Analyzers" />
        <dependency id="System.Data.SQLite.Core" version="1.0.115.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="FreeSql" version="3.2.698" exclude="Build,Analyzers" />
        <dependency id="System.Data.SQLite.Core" version="1.0.115.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>