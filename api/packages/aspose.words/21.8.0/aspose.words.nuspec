    <id>Aspose.Words</id>
    <version>21.8.0</version>
    <title>Aspose.Words for .NET</title>
    <authors>Aspose</authors>
    <owners>Aspose</owners>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
