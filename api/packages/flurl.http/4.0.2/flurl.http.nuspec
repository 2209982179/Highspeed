<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Flurl.Http</id>
    <version>4.0.2</version>
    <authors>Todd Menier</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://flurl.dev/</projectUrl>
    <description>A fluent, testable HTTP client library.</description>
    <releaseNotes>https://github.com/tmenier/Flurl/releases</releaseNotes>
    <copyright>Copyright (c) Todd Menier 2024.</copyright>
    <tags>rest http httpclient json url uri tdd</tags>
    <repository type="git" url="https://github.com/tmenier/Flurl.git" commit="c3b9bb88fbbf026f748146e4648125f5ca066534" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.1">
        <dependency id="Flurl" version="4.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="6.0.4" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net6.0">
        <dependency id="Flurl" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Flurl" version="4.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Text.Encoding.CodePages" version="4.5.1" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="6.0.4" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="System.Net.Http" targetFramework=".NETFramework4.6.1" />
    </frameworkAssemblies>
  </metadata>
</package>