<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Numerics.NET</id>
    <version>9.1.2</version>
    <authors>ExoAnalytics Inc.</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="file">License.md</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <icon>icon.png</icon>
    <readme>docs\README.md</readme>
    <projectUrl>https://numerics.net/</projectUrl>
    <description>Numerics.NET (formerly Extreme Optimization Numerical Libraries for .NET) are a set of libraries for numerical computing and data analysis.

This package bundles all functionality except for native libraries.

For optimal performance, we strongly recommend also referencing one of the native packages based on Intel's Math Kernel Library (MKL).

Supports .NET 6.0-9.0+, .NET Framework 4.62+, .NET Standard 2.0 on Windows, Linux and Mac.</description>
    <summary>Numerics.NET - math, statistics, and data analysis libraries for .NET.</summary>
    <releaseNotes>See individual packages for details.</releaseNotes>
    <copyright>Copyright © 2004-2025, ExoAnalytics Inc. All rights reserved.</copyright>
    <tags>math statistics probability machine learning ml numerics linear algebra matrix vector solve optimization curve fit model fft integration differentiation interpolation regression</tags>
    <dependencies>
      <group>
        <dependency id="Numerics.NET.Core" version="9.1.2" exclude="Build,Analyzers" />
        <dependency id="Numerics.NET.Tensors" version="9.0.4" exclude="Build,Analyzers" />
        <dependency id="Numerics.NET.Generic" version="9.1.2" exclude="Build,Analyzers" />
        <dependency id="Numerics.NET.SinglePrecision" version="9.1.2" exclude="Build,Analyzers" />
        <dependency id="Numerics.NET.Data" version="4.0.4" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>